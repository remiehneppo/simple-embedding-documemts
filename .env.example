# simple-embed environment variables
# Copy this file to .env and adjust values as needed.

# ── API server ────────────────────────────────────────────────────────────────
APP_NAME=simple-embed
DEBUG=false
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── Paths (relative to project root, or absolute) ─────────────────────────────
STORAGE_PATH=storage
DOCUMENTS_PATH=storage/documents
CHROMA_PATH=storage/chroma_db
LOG_PATH=logs

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=embeddinggemma:300m-qat-q8_0
EMBED_BATCH_SIZE=32
OLLAMA_TIMEOUT=60.0
OLLAMA_MAX_RETRIES=3

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_MAX_WORDS=50
CHUNK_OVERLAP_WORDS=10
CHUNK_MIN_WORDS=5

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_COLLECTION=documents

# ── Search ────────────────────────────────────────────────────────────────────
SEARCH_TOP_K=10
SEARCH_REGEX_POOL_LIMIT=5000

# ── OCR ───────────────────────────────────────────────────────────────────────
OCR_LANGS=en,vi,ru

# ── CLI (set this when using cli/main.py against a remote or Docker instance) ─
# EMBED_API_URL=http://localhost:8000
