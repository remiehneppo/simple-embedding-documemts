FROM alpine/ollama:latest

# Set model storage path
ENV OLLAMA_MODELS=/root/.ollama/models

# Model to bake in — override with: docker build --build-arg OLLAMA_MODEL=...
ARG OLLAMA_MODEL=embeddinggemma:300m-qat-q8_0

# Persist the model name so the entrypoint can reference it at runtime
ENV OLLAMA_MODEL=${OLLAMA_MODEL}

# Pull model at build time so the exported image already contains it.
# No internet access is required when running the container.
RUN ollama serve & \
    OLLAMA_PID=$! && \
    echo "[build] Waiting for Ollama server..." && \
    until ollama list >/dev/null 2>&1; do sleep 2; done && \
    echo "[build] Server ready. Pulling model ${OLLAMA_MODEL} (this may take a while)..." && \
    ollama pull "${OLLAMA_MODEL}" 2>&1; \
    PULL_EXIT=$?; \
    echo "[build] Pull finished with exit code $PULL_EXIT"; \
    kill $OLLAMA_PID; \
    wait $OLLAMA_PID 2>/dev/null; \
    exit $PULL_EXIT

# Expose API
EXPOSE 11434

# Use the entrypoint script: verifies model is present (fail-fast), then serves.
# No internet pull is attempted at container start.
COPY docker/ollama-entrypoint.sh /ollama-entrypoint.sh
RUN chmod +x /ollama-entrypoint.sh

ENTRYPOINT ["/ollama-entrypoint.sh"]